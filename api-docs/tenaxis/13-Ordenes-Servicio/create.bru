    "horaFinReal": "2026-03-20T15:00:00.000Z",
    "duracionMinutos": 50,
    "facturaElectronica": "",
    "comprobantePago": "",
    "evidenciaPath": "",
    "valorPagado": 0,
    "observacionFinal": "",
