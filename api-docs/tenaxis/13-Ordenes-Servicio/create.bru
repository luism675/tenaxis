meta {
  name: Create Orden Servicio
  type: http
  seq: 1
}

post {
  url: {{local}}/ordenes-servicio
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "clienteId": "{{clienteId}}",
    "empresaId": "{{enterpriseId}}",
    "direccionId": "{{direccionId}}",
