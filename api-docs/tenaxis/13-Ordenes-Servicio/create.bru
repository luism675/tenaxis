    "liquidadoPorId": "{{membershipId}}",
    "estadoServicio": "PENDIENTE",
    "estadoPago": "PENDIENTE",
    "fechaVisita": "2026-03-20T14:00:00.000Z",
    "horaInicio": "2026-03-20T14:00:00.000Z",
