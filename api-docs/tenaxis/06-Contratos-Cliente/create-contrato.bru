meta {
  name: Create Contrato
  type: http
  seq: 3
}

post {
  url: {{local}}/clientes/{{clienteId}}/contratos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "empresaId": "{{enterpriseId}}",
    "fechaInicio": "2026-03-01",
    "fechaFin": "2026-12-31",
    "serviciosComprometidos": 12,
    "frecuenciaServicio": 30,
    "tipoFacturacion": "MENSUAL",
    "estado": "ACTIVO",
    "observaciones": "Contrato anual de mantenimiento"
  }
}
